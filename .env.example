# .env.example - Copy this to .env and fill in your values

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development

# ==================== DATABASE (PostgreSQL) ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_video_editor
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ==================== REDIS ====================
REDIS_URL=redis://localhost:6379

# ==================== AUTHENTICATION ====================
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ==================== LOCAL STORAGE ====================
# Temporary directory for downloaded/processed files
LOCAL_STORAGE=./uploads

# ==================== AI / TRANSCRIPTION APIs ====================

# Descript - Premium transcription (https://www.descript.com/developers)
DESCRIPT_API_KEY=your_descript_api_key

# AssemblyAI - Speech-to-text with speaker identification (https://www.assemblyai.com)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# ==================== GOOGLE CLOUD ====================
# Google Cloud Translation API
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id
# Path to your Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# ==================== VIDEO AI APIs ====================

# Topaz Video AI - Color grading (https://www.topazlabs.com)
TOPAZ_API_KEY=your_topaz_api_key

# Runway ML - Face detection & auto-reframing (https://runwayml.com)
RUNWAY_API_KEY=your_runway_api_key

# iZotope RX - Audio enhancement (optional, FFmpeg fallback will be used)
IZOTOPE_API_KEY=your_izotope_api_key

# ==================== CLAUDE AI ====================
# Anthropic Claude - Effect suggestions (https://www.anthropic.com)
CLAUDE_API_KEY=your_anthropic_api_key

# ==================== QUEUE WORKER ====================
# Number of videos to process in parallel
QUEUE_CONCURRENCY=2

# ==================== VIDEO PROCESSING ====================
# Scene detection sensitivity (0.0 - 1.0, lower = more sensitive)
SCENE_DETECTION_THRESHOLD=0.3

# Maximum upload size in megabytes (default: 500)
MAX_FILE_SIZE_MB=500

# CORS allowed origin (use * for all, or specify your frontend URL)
CORS_ORIGIN=http://localhost:5173
